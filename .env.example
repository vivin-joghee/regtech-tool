# Strait Compliance — environment template
# Copy to .env.local for local development. Never commit .env.local.

# Neon Postgres connection
# - Use the DEV branch URL for local development.
# - Use the PRODUCTION branch URL only from deployed Cloudflare Workers.
# Get the latest URLs from the Neon console or via `wrangler secret put`.

DATABASE_URL=postgresql://USER:PASSWORD@HOST.ap-southeast-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Cloudflare account
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_API_TOKEN=your-token-here

# App config
APP_ENV=local
LOG_LEVEL=debug
